# Base de données PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/f1_fantasy?schema=public"
ADMIN_PASSWORD="votre-mot-de-passe-admin-ici"
# NextAuth
# Générer avec: openssl rand -base64 32
NEXTAUTH_SECRET="votre-secret-aleatoire-ici"
NEXTAUTH_URL="http://localhost:3000"

# En production sur AWS Amplify :
# NEXTAUTH_URL sera l'URL de votre app Amplify
# DATABASE_URL pointera vers votre instance AWS RDS
