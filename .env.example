# Base de données PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/f1_fantasy?schema=public"
ADMIN_PASSWORD="votre-mot-de-passe-admin-ici"
# NextAuth
# Générer avec: openssl rand -base64 32
NEXTAUTH_SECRET="votre-secret-aleatoire-ici"
NEXTAUTH_URL="http://localhost:3000"

# En production sur AWS Amplify :
# NEXTAUTH_URL sera l'URL de votre app Amplify
# DATABASE_URL pointera vers votre instance AWS RDS


# Setup Gmail App Password (5 min) :
# Va sur myaccount.google.com/security
# Active la validation en 2 étapes si pas déjà fait
# Cherche "Mots de passe des applications" → crée-en un nommé "F1 Fantasy"
# Copie le mot de passe de 16 caractères → GMAIL_APP_PASSWORD

CRON_SECRET="votre-secret-pour-taches-cron-ici"
GMAIL_USER="compte@gmail.com"
GMAIL_APP_PASSWORD="votre-clé-api-gmail-ici"
NEXT_PUBLIC_APP_URL="https://monapp.vercel.app/"